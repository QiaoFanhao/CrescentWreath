# =========================
# Root gitignore for CrescentWreath mono-repo
# =========================

# ---------- Common ----------
.DS_Store
Thumbs.db
*.log
.vs/
.idea/
.gradle/
TestResults/

# ---------- .NET / C# ----------
**/bin/
**/obj/
*.user
*.rsuser
*.suo
*.tmp
*.userprefs
*.pidb
*.booproj
*.svd
*.opendb
*.VC.db

# Keep solution and project files tracked
!*.sln
!*.csproj

# ---------- Unity (only relevant for UnityClient or future Unity project dirs) ----------
[Ll]ibrary/
[Tt]emp/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/
ExportedObj/
sysinfo.txt
mono_crash.*

# Unity generated / optional
*.unitypackage
*.unitypackage.meta
*.apk
*.aab
*.app

# Addressables
/ServerData
/[Aa]ssets/StreamingAssets/aa*
/[Aa]ssets/AddressableAssetsData/link.xml*
/[Aa]ssets/Addressables_Temp*
/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Rider / JetBrains
*.DotSettings.user
/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Scripting
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# ---------- Optional local artifacts ----------
*.zip